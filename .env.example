# ai-life-agent 环境配置示例
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
# .env 文件已被 .gitignore 排除，不会提交到版本库。

# ---- 必填 ----
# MiniMax API 密钥（从 https://platform.minimaxi.com 获取）
MINIMAX_API_KEY=your_minimax_api_key_here

# ---- 可选（有默认值）----
# 对话模型（可选：MiniMax-M2.7 / MiniMax-M2.7-highspeed / MiniMax-M2.5）
# CHAT_MODEL=MiniMax-M2.7

# TTS 模型（可选：speech-2.8-hd / speech-2.8-turbo / speech-02-hd / speech-02-turbo）
# TTS_MODEL=speech-02-hd

# 最大生成 Token 数
# MAX_TOKENS=4096

# ReAct 循环最大迭代次数
# MAX_REACT_ITERATIONS=10

# 是否开启详细日志（显示思维链 + 工具调用）
# VERBOSE=false
